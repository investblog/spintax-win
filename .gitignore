# Baseline (from the canon library's template) + the Free Pascal stack.

# secrets — never commit (templates like .env.example are kept)
.env
.env.*
!.env.example
.dev.vars
.secrets
*.pem
id_rsa
id_ed25519

# dependencies
node_modules/
.venv/
venv/
__pycache__/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# build / generated artifacts
dist/
build/
.wrangler/
*.log

# local indexes — regenerable caches (code-search / content-vault); never commit
.codegraph/
.docindex/

# OS junk
.DS_Store
Thumbs.db

# --- Free Pascal / Delphi ---
# compiler units and intermediates
*.o
*.ppu
*.or
*.a
*.compiled
*.res
*.rsj
*.dcu
lib/
backup/
__history/
__recovery/

# fpc drops its link script beside the sources; -Cn (the warnings gate) leaves one behind
ppas.bat
ppas.sh

# built binaries (fpc -o targets; Windows adds .exe)
tests/corpus_runner
tests/corpus_runner.exe
tests/local_tests
tests/local_tests.exe
tests/local_tests_checked
tests/local_tests_checked.exe
examples/demo
examples/demo.exe

# Lazarus / Delphi per-user session state — machine-local, never shared
*.lps
*.identcache
*.local
*.dproj.local
*.dsk

# Delphi IDE build output (the probe in tests/delphi is built by hand in the IDE)
Win32/
Win64/
Debug/
Release/
tests/delphi/probe_fpc
tests/delphi/*.exe

# Agent working state, not the product. None of it is useful to someone reading this
# repository: it is instructions for the tooling that maintains the engine, plus a
# settings file pinning an absolute shell path that would break on any other machine.
# Everything a consumer or a porter needs is in README.md and docs/spec-pascal-port.md.
#
# All of it stays ON DISK, so a session opened in this working copy still gets its
# charter; only the repository is kept free of it. The git hooks it drives are local
# convenience and CI runs the same checks independently.
.claude/
.agents/
AGENTS.md
CLAUDE.md
